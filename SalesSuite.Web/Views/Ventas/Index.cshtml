@model X.PagedList.IPagedList<SalesSuite.Web.DTOs.VentaDTO>
@{ ViewData["Title"] = "Ventas"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-receipt me-2"></i>Registro de Ventas</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i> Nueva Venta
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Fecha y Hora</th>
                    <th>Cliente</th>
                    <th class="text-center">Productos</th>
                    <th class="text-end">Total</th>
                    <th class="text-center">Detalle</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in Model)
                {
                    <tr>
                        <td><code>@v.Id</code></td>
                        <td>@v.FechaVenta.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@v.ClienteNombre</td>
                        <td class="text-center">
                            <span class="badge bg-secondary">@v.TotalProductos uds.</span>
                        </td>
                        <td class="text-end fw-bold text-success">
                            S/. @v.Total.ToString("N2")
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@v.Id"
                               class="btn btn-sm btn-outline-info">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No hay ventas registradas.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.PageCount > 1)
{
    <div class="d-flex justify-content-between align-items-center mt-3">
        <small class="text-muted">Página @Model.PageNumber de @Model.PageCount</small>
        @Html.PagedListPager(Model, p => Url.Action("Index", new { pagina = p })!)
    </div>
}
