@model X.PagedList.IPagedList<SalesSuite.Web.DTOs.ClienteDTO>
@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people me-2"></i>Clientes</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-person-plus me-1"></i> Nuevo Cliente
    </a>
</div>

<form asp-action="Index" method="get" class="row g-2 mb-4">
    <div class="col-md-8">
        <input type="text" name="busqueda" value="@ViewBag.Busqueda"
               class="form-control" placeholder="Buscar por nombre, apellido o documento..." />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-search"></i> Buscar
        </button>
    </div>
    @if (!string.IsNullOrEmpty(ViewBag.Busqueda))
    {
        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">
                <i class="bi bi-x-circle"></i> Limpiar
            </a>
        </div>
    }
</form>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead>
                <tr>
                    <th>Documento</th>
                    <th>Nombre Completo</th>
                    <th>Email</th>
                    <th>Teléfono</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td><code>@c.DocumentoIdentidad</code></td>
                        <td>@c.NombreCompleto</td>
                        <td>@(c.Email ?? "—")</td>
                        <td>@(c.Telefono ?? "—")</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@c.Id"
                               class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@c.Id"
                               class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            No se encontraron clientes.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.PageCount > 1)
{
    <div class="d-flex justify-content-between align-items-center mt-3">
        <small class="text-muted">Página @Model.PageNumber de @Model.PageCount</small>
        @Html.PagedListPager(Model, p => Url.Action("Index", new { pagina = p, busqueda = ViewBag.Busqueda })!)
    </div>
}
